rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function familyData(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)).data;
    }

    function isOwner(familyId) {
      return isAuth() && familyData(familyId).ownerId == uid();
    }

    function isAdmin(familyId) {
      return isAuth() && (
        isOwner(familyId) ||
        uid() in familyData(familyId).get('adminIds', [])
      );
    }

    function isMember(familyId) {
      return isAuth() && uid() in familyData(familyId).get('members', []);
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    // Any authenticated user can read user profiles (needed for member lists).
    // Users may only write their own document.

    match /users/{userId} {
      allow read:  if isAuth();
      allow write: if isAuth() && uid() == userId;
    }

    // ── Families ───────────────────────────────────────────────────────────────

    match /families/{familyId} {

      // Any family member can read the family document.
      allow read: if isMember(familyId);

      // Creator must be listed as ownerId and in members on creation.
      allow create: if isAuth()
        && request.resource.data.ownerId == uid()
        && uid() in request.resource.data.get('members', []);

      // Owner can update any field.
      allow update: if isOwner(familyId);

      // Admin can update the members array only — cannot touch ownerId or adminIds.
      allow update: if isAdmin(familyId)
        && request.resource.data.ownerId   == resource.data.ownerId
        && request.resource.data.adminIds  == resource.data.adminIds;

      // Any authenticated user may join (add themselves to members) as long as
      // they don't alter ownerId, adminIds, or remove anyone else.
      allow update: if isAuth()
        && request.resource.data.ownerId  == resource.data.ownerId
        && request.resource.data.adminIds == resource.data.adminIds
        && request.resource.data.members.hasAll(resource.data.members)
        && request.resource.data.members.hasOnly(resource.data.members.concat([uid()]));

      // Only the owner may delete the family document.
      allow delete: if isOwner(familyId);

      // ── Subcollections ──────────────────────────────────────────────────────
      // Family members have full read/write access to all subcollections
      // (events, albums, chats, messages, notes, etc.)

      match /{subcollection}/{docId} {
        allow read, write: if isMember(familyId);

        // Nested subcollections (e.g. albums/{albumId}/photos/{photoId})
        match /{nestedCollection}/{nestedDocId} {
          allow read, write: if isMember(familyId);
        }
      }
    }
  }
}
